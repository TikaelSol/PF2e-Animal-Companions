{
  "name": "Cephalopod",
  "type": "ancestry",
  "effects": [],
  "system": {
    "description": {
      "gm": "",
      "value": "<p>Your companion is an octopus, squid, nautilus, or other cephalopod.</p><p><strong>Size</strong> Small</p><p><strong>Melee</strong> <span class=\"pf2-icon\">1</span> beak (finesse), Damage 1d6 piercing</p><p><strong>Melee</strong> <span class=\"pf2-icon\">1</span> arm (agile, finesse), Damage 1d4 bludgeoning</p><p><strong>Str</strong> +2, <strong>Dex</strong> +3, <strong>Con</strong> +2, <strong>Int</strong> –4, <strong>Wis</strong> +1, <strong>Cha</strong> +0</p><p><strong>Hit Points</strong> 6</p><p><strong>Skill</strong> Stealth</p><p><strong>Senses</strong> low-light vision</p><p><strong>Speed</strong> 10 feet, swim 30 feet</p><p><strong>Support Benefit</strong> Your cephalopod squirts ink into your foe's face. Until the start of your next turn, if you hit and deal damage to a creature in your cephalopod's reach, the creature takes a –1 circumstance penalty to their attacks until the start of your next turn.</p><p><strong>Advanced Maneuver</strong> @UUID[Compendium.pf2e-animal-companions.AC-Advanced-Maneuvers.Item.Z5BaXVwWhAOFf4NY]{Crushing Embrace}</p>"
    },
